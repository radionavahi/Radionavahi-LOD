        <rdfs:label xml:lang="en">Regional Repertoire</rdfs:label>
        <rdfs:label xml:lang="fa">موسیقی نواحی</rdfs:label>
    </owl:Class>

    <!-- ClassicalRepertoire -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#ClassicalRepertoire">
