<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.radionavahi.org/ontology/test#"
     xml:base="http://www.radionavahi.org/ontology/test"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dct="http://purl.org/dc/terms/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:bibo="http://purl.org/ontology/bibo/"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:cc="http://creativecommons.org/ns#"
     xmlns:test="http://www.radionavahi.org/ontology/test#">

    <owl:Ontology rdf:about="http://www.radionavahi.org/ontology/test">
        <dct:title xml:lang="en">A Linked Open Data model of Iranian regional and ritual music</dct:title>
        <dct:title xml:lang="fa">میکروگراف رادیونواحی</dct:title>
        <rdfs:label xml:lang="en">Radionavahi LOD Micro-graph</rdfs:label>
        <rdfs:label xml:lang="fa">میکروگراف رادیونواحی</rdfs:label>

        <dct:description xml:lang="en">The Radionavahi Micro-graph is a curated conceptual knowledge graph that represents the universe of Iranian regional musics, instruments, ritual contexts, performers, and ethnic groups documented in the Radionavahi archive (https://radionavahi.com). It demonstrates the methodological transition from a document-based archive to a Linked Open Data resource that participates in the wider semantic web. The model follows ACUSTEME principles as a reference: it preserves emic categories, maintains semantic interoperability with external knowledge bases (Wikidata, GeoNames) via lightweight rdfs:seeAlso links, and avoids over-complex ontology design.</dct:description>
        <dct:abstract xml:lang="en">A curated conceptual knowledge graph of Iranian regional and ritual musics, derived from the Radionavahi archive and aligned with ACUSTEME methodological principles. Designed for visualization in Protégé and WebVOWL; serves as a Linked Open Data demonstrator for ethnomusicological data modeling.</dct:abstract>
        <rdfs:comment xml:lang="en">A Linked Open Data demonstrator for Iranian ethnomusicological data.</rdfs:comment>

        <dct:creator>
            <foaf:Person>
                <foaf:name>Radionavahi-LOD project</foaf:name>
                <foaf:homepage rdf:resource="https://radionavahi.com"/>
            </foaf:Person>
        </dct:creator>
        <dct:contributor>Hossein Ebrahimi</dct:contributor>
        <dct:publisher>Radionavahi</dct:publisher>

        <owl:versionInfo>2.1.0</owl:versionInfo>
        <owl:versionIRI rdf:resource="http://www.radionavahi.org/ontology/test/2.1.0"/>
        <bibo:status rdf:resource="http://purl.org/ontology/bibo/status/published"/>
        <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026</dct:issued>
        <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026</dct:modified>

        <dct:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <cc:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dct:rights xml:lang="en"></dct:rights>

        <vann:preferredNamespacePrefix>test</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://www.radionavahi.org/ontology/test#</vann:preferredNamespaceUri>

        <dct:source rdf:resource="https://radionavahi.com"/>
        <rdfs:seeAlso rdf:resource="https://github.com/radionavahi/Radionavahi-LOD"/>
        <rdfs:seeAlso rdf:resource="https://ontology.acusteme.org/EN/LODEen_files/extracten.htm"/>
        <foaf:homepage rdf:resource="https://github.com/radionavahi/Radionavahi-LOD"/>

        <dc:language>en</dc:language>
        <dc:language>fa</dc:language>
        <dct:language rdf:resource="http://lexvo.org/id/iso639-3/eng"/>
        <dct:language rdf:resource="http://lexvo.org/id/iso639-3/fas"/>

        <dct:subject xml:lang="en">Iranian music</dct:subject>
        <dct:subject xml:lang="en">Ethnomusicology</dct:subject>
        <dct:subject xml:lang="en">Linked Open Data</dct:subject>
        <dct:subject xml:lang="en">Cultural heritage</dct:subject>
        <dct:subject xml:lang="en">Digital humanities</dct:subject>
    </owl:Ontology>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- belongsToGenre -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#belongsToGenre">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.radionavahi.org/ontology/test#Instrument"/>
                    <rdf:Description rdf:about="http://www.radionavahi.org/ontology/test#Ritual"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:label xml:lang="en">belongs to genre</rdfs:label>
        <rdfs:label xml:lang="fa">متعلق است به گونه</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that an instrument or a ritual is constitutively associated with a particular musical genre. The relation is many-to-many: an instrument can belong to multiple genres, and a genre comprises multiple instruments and rituals.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- isPlayedIn -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#isPlayedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.radionavahi.org/ontology/test#Instrument"/>
                    <rdf:Description rdf:about="http://www.radionavahi.org/ontology/test#Ritual"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">is played in</rdfs:label>
        <rdfs:label xml:lang="fa">اجرا می‌شود در</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that an instrument is performed in a region, or that a ritual takes place in a region. The two senses are united because both are claims about the geographic anchoring of a musical or ritual practice.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- playsInstrument -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#playsInstrument">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Artist"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Instrument"/>
        <rdfs:label xml:lang="en">plays instrument</rdfs:label>
        <rdfs:label xml:lang="fa">می‌نوازد</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that an artist performs on a particular instrument. An artist may play multiple instruments; the relation does not encode primary versus secondary instruments.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- takesPlaceIn -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#takesPlaceIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Ritual"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">takes place in</rdfs:label>
        <rdfs:label xml:lang="fa">برگزار می‌شود در</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that a ritual is performed in a particular region. More specific than isPlayedIn — used when the ritual itself, not merely its musical accompaniment, is anchored to the region.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- originatesIn -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#originatesIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">originates in</rdfs:label>
        <rdfs:label xml:lang="fa">سرچشمه می‌گیرد از</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that a musical genre originated in a particular region. Captures the claim that the genre was *born* there, distinct from the regions where it is currently performed.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- usesInstrument -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#usesInstrument">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Instrument"/>
        <rdfs:label xml:lang="en">uses instrument</rdfs:label>
        <rdfs:label xml:lang="fa">به‌کار می‌برد ساز</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that a musical genre conventionally uses a particular instrument in its performance practice. The inverse relation of belongsToGenre when the subject is an instrument.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- practicedBy -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#practicedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Ritual"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#EthnicGroup"/>
        <rdfs:label xml:lang="en">practiced by</rdfs:label>
        <rdfs:label xml:lang="fa">عمل می‌شود توسط</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that a ritual is constitutively practiced by a particular ethnic group. Captures the bearer relationship: the ritual is *theirs* in the sense of cultural ownership.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- nativeTo -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#nativeTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#EthnicGroup"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">native to</rdfs:label>
        <rdfs:label xml:lang="fa">بومی است در</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that an ethnic group is native to a particular region — their geographic origin or principal area of settlement.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- performsGenre -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#performsGenre">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Artist"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:label xml:lang="en">performs genre</rdfs:label>
        <rdfs:label xml:lang="fa">اجرا می‌کند گونه</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that an artist performs in a particular musical genre. Complementary to playsInstrument: a performer's genre identity is not always reducible to the instrument played.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- bornIn -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#bornIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Artist"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">born in</rdfs:label>
        <rdfs:label xml:lang="fa">متولد است در</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts that an artist was born in a particular region. Biographical anchoring, distinct from the regions where the artist performs.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- influencedBy -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#influencedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:label xml:lang="en">influenced by</rdfs:label>
        <rdfs:label xml:lang="fa">تأثیر گرفته از</rdfs:label>
        <rdfs:comment xml:lang="en">Asserts a genealogical or stylistic influence between two musical genres. Direction matters: A influencedBy B claims that B preceded and shaped A, not the reverse.</rdfs:comment>
    </owl:ObjectProperty>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatype Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- hasFloruitDate -->
    <owl:DatatypeProperty rdf:about="http://www.radionavahi.org/ontology/test#hasFloruitDate">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Artist"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:label xml:lang="en">has floruit date</rdfs:label>
        <rdfs:label xml:lang="fa">تاریخ زندگی</rdfs:label>
        <rdfs:comment xml:lang="en">The decade or year in which an artist was active and at the height of their documented career. Used in lieu of birth/death dates when those are unknown.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- hasUNESCOInscription -->
    <owl:DatatypeProperty rdf:about="http://www.radionavahi.org/ontology/test#hasUNESCOInscription">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has UNESCO ICH inscription</rdfs:label>
        <rdfs:label xml:lang="fa">شمارهٔ ثبت یونسکو</rdfs:label>
        <rdfs:comment xml:lang="en">The UNESCO Intangible Cultural Heritage register number for a genre or ritual. References the Representative List of the Intangible Cultural Heritage of Humanity.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- hasLatinTransliteration -->
    <owl:DatatypeProperty rdf:about="http://www.radionavahi.org/ontology/test#hasLatinTransliteration">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">Latin transliteration</rdfs:label>
        <rdfs:label xml:lang="fa">حرف‌نویسی لاتین</rdfs:label>
        <rdfs:comment xml:lang="en">The scholarly Latin-script transliteration of a Persian name, distinct from the more loosely Anglicized rdfs:label. Follows the conventions used in academic ethnomusicology literature.</rdfs:comment>
    </owl:DatatypeProperty>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- Artist -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#Artist">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:label xml:lang="en">Artist</rdfs:label>
        <rdfs:label xml:lang="fa">هنرمند</rdfs:label>
        <rdfs:comment xml:lang="en">A performer, singer, or instrumentalist documented in the Radionavahi archive. Includes folk musicians, ritual leaders, and tradition-bearers across Iranian regional and ethnic communities.</rdfs:comment>
    </owl:Class>

    <!-- Instrument -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#Instrument">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:label xml:lang="en">Instrument</rdfs:label>
        <rdfs:label xml:lang="fa">ساز</rdfs:label>
        <rdfs:comment xml:lang="en">A musical instrument used in the Iranian regional musical traditions documented in the archive. Sub-classed by organological family (string, wind, percussion).</rdfs:comment>
    </owl:Class>

    <!-- StringInstrument -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#StringInstrument">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:subClassOf rdf:resource="http://www.radionavahi.org/ontology/test#Instrument"/>
        <rdfs:label xml:lang="en">String Instrument</rdfs:label>
        <rdfs:label xml:lang="fa">ساز زهی</rdfs:label>
        <rdfs:comment xml:lang="en">A musical instrument that produces sound through the vibration of strings, plucked or bowed. Includes lutes, fiddles, and zithers in the Iranian organological tradition.</rdfs:comment>
    </owl:Class>

    <!-- WindInstrument -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#WindInstrument">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:subClassOf rdf:resource="http://www.radionavahi.org/ontology/test#Instrument"/>
        <rdfs:label xml:lang="en">Wind Instrument</rdfs:label>
        <rdfs:label xml:lang="fa">ساز بادی</rdfs:label>
        <rdfs:comment xml:lang="en">A musical instrument that produces sound through a vibrating column of air. Includes flutes, double-reeds, and bagpipes characteristic of southern and north-eastern Iranian regional music.</rdfs:comment>
    </owl:Class>

    <!-- PercussionInstrument -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#PercussionInstrument">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:subClassOf rdf:resource="http://www.radionavahi.org/ontology/test#Instrument"/>
        <rdfs:label xml:lang="en">Percussion Instrument</rdfs:label>
        <rdfs:label xml:lang="fa">ساز کوبه‌ای</rdfs:label>
        <rdfs:comment xml:lang="en">A musical instrument that produces sound when struck or shaken. Includes frame drums, cylindrical drums, and idiophones used in Iranian ceremonial and ritual contexts.</rdfs:comment>
    </owl:Class>

    <!-- Ritual -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#Ritual">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:label xml:lang="en">Ritual</rdfs:label>
        <rdfs:label xml:lang="fa">آیین</rdfs:label>
        <rdfs:comment xml:lang="en">A bounded ritual or ceremonial context in which music is performed or that is constituted in part by music. Sub-classed by social function (life-cycle, healing, devotional).</rdfs:comment>
    </owl:Class>

    <!-- LifeCycleRitual -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#LifeCycleRitual">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:subClassOf rdf:resource="http://www.radionavahi.org/ontology/test#Ritual"/>
        <rdfs:label xml:lang="en">Life-cycle Ritual</rdfs:label>
        <rdfs:label xml:lang="fa">آیین چرخهٔ زندگی</rdfs:label>
        <rdfs:comment xml:lang="en">A ritual that marks a transition in the human life cycle: birth, marriage, death, and the recurring observances around them. Includes weddings, mournings, and lullabies.</rdfs:comment>
    </owl:Class>

    <!-- HealingRitual -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#HealingRitual">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:subClassOf rdf:resource="http://www.radionavahi.org/ontology/test#Ritual"/>
        <rdfs:label xml:lang="en">Healing Ritual</rdfs:label>
        <rdfs:label xml:lang="fa">آیین درمانی</rdfs:label>
        <rdfs:comment xml:lang="en">A ritual whose primary social function is therapeutic, addressing physical, psychological, or spiritual ailments through musical and choreographic means. Includes the Zar and Guati traditions.</rdfs:comment>
    </owl:Class>

    <!-- DevotionalRitual -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#DevotionalRitual">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:subClassOf rdf:resource="http://www.radionavahi.org/ontology/test#Ritual"/>
        <rdfs:label xml:lang="en">Devotional Ritual</rdfs:label>
        <rdfs:label xml:lang="fa">آیین آیینی-عرفانی</rdfs:label>
        <rdfs:comment xml:lang="en">A ritual centered on religious or mystical devotion, including Sufi gatherings, Shia mourning ceremonies, and passion plays. Music is constitutive rather than incidental.</rdfs:comment>
    </owl:Class>

    <!-- MusicalGenre -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#MusicalGenre">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:label xml:lang="en">Musical Genre</rdfs:label>
        <rdfs:label xml:lang="fa">گونهٔ موسیقایی</rdfs:label>
        <rdfs:comment xml:lang="en">A category of musical repertoire defined by regional provenance, performance practice, or social context. Sub-classed by tradition type (regional vs. classical).</rdfs:comment>
    </owl:Class>

    <!-- RegionalRepertoire -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#RegionalRepertoire">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:subClassOf rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:label xml:lang="en">Regional Repertoire</rdfs:label>
        <rdfs:label xml:lang="fa">موسیقی نواحی</rdfs:label>
        <rdfs:comment xml:lang="en">A musical genre that is geographically anchored — a "moosighi-ye nahieh" or regional music — defined by local instrumentation, modal practice, and performance occasions.</rdfs:comment>
    </owl:Class>

    <!-- ClassicalRepertoire -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#ClassicalRepertoire">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:subClassOf rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:label xml:lang="en">Classical Repertoire</rdfs:label>
        <rdfs:label xml:lang="fa">موسیقی کلاسیک</rdfs:label>
        <rdfs:comment xml:lang="en">The classical Persian art-music tradition (radif), distinguished from regional repertoires by its codified modal system, court patronage, and pan-Iranian rather than regional identity.</rdfs:comment>
    </owl:Class>

    <!-- Region -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#Region">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:label xml:lang="en">Region</rdfs:label>
        <rdfs:label xml:lang="fa">منطقه</rdfs:label>
        <rdfs:comment xml:lang="en">A geographic location relevant to the Radionavahi archive: a province, city, or culturally-defined area within Iran or its near neighbours where particular musical traditions are documented.</rdfs:comment>
    </owl:Class>

    <!-- EthnicGroup -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#EthnicGroup">
        <rdfs:isDefinedBy rdf:resource="http://www.radionavahi.org/ontology/test"/>
        <rdfs:label xml:lang="en">Ethnic Group</rdfs:label>
        <rdfs:label xml:lang="fa">قوم</rdfs:label>
        <rdfs:comment xml:lang="en">An ethno-linguistic community whose musical practices are documented in the archive. Membership is constituted by shared language, descent, and cultural practice.</rdfs:comment>
    </owl:Class>

