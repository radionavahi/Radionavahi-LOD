<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.radionavahi.org/ontology/test#"
     xml:base="http://www.radionavahi.org/ontology/test"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:test="http://www.radionavahi.org/ontology/test#">
    <owl:Ontology rdf:about="http://www.radionavahi.org/ontology/test">
        <rdfs:comment xml:lang="en">Radionavahi micro-graph (v2, schema-enriched): a curated conceptual model of Iranian regional and ritual musics. Adds class hierarchy, EthnicGroup class, datatype properties, and ~80 individuals across 12 specialized classes.</rdfs:comment>
        <rdfs:label xml:lang="en">Radionavahi Micro-graph v2</rdfs:label>
        <rdfs:label xml:lang="fa">میکروگراف رادیونواحی (نسخهٔ ۲)</rdfs:label>
    </owl:Ontology>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- belongsToGenre -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#belongsToGenre">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.radionavahi.org/ontology/test#Instrument"/>
                    <rdf:Description rdf:about="http://www.radionavahi.org/ontology/test#Ritual"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:label xml:lang="en">belongs to genre</rdfs:label>
        <rdfs:label xml:lang="fa">متعلق است به گونه</rdfs:label>
    </owl:ObjectProperty>

    <!-- isPlayedIn -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#isPlayedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.radionavahi.org/ontology/test#Instrument"/>
                    <rdf:Description rdf:about="http://www.radionavahi.org/ontology/test#Ritual"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">is played in</rdfs:label>
        <rdfs:label xml:lang="fa">اجرا می‌شود در</rdfs:label>
    </owl:ObjectProperty>

    <!-- playsInstrument -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#playsInstrument">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Artist"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Instrument"/>
        <rdfs:label xml:lang="en">plays instrument</rdfs:label>
        <rdfs:label xml:lang="fa">می‌نوازد</rdfs:label>
    </owl:ObjectProperty>

    <!-- takesPlaceIn -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#takesPlaceIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Ritual"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">takes place in</rdfs:label>
        <rdfs:label xml:lang="fa">برگزار می‌شود در</rdfs:label>
    </owl:ObjectProperty>

    <!-- originatesIn -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#originatesIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">originates in</rdfs:label>
        <rdfs:label xml:lang="fa">سرچشمه می‌گیرد از</rdfs:label>
    </owl:ObjectProperty>

    <!-- usesInstrument -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#usesInstrument">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Instrument"/>
        <rdfs:label xml:lang="en">uses instrument</rdfs:label>
        <rdfs:label xml:lang="fa">به‌کار می‌برد ساز</rdfs:label>
    </owl:ObjectProperty>

    <!-- practicedBy -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#practicedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Ritual"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#EthnicGroup"/>
        <rdfs:label xml:lang="en">practiced by</rdfs:label>
        <rdfs:label xml:lang="fa">عمل می‌شود توسط</rdfs:label>
    </owl:ObjectProperty>

    <!-- nativeTo -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#nativeTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#EthnicGroup"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">native to</rdfs:label>
        <rdfs:label xml:lang="fa">بومی است در</rdfs:label>
    </owl:ObjectProperty>

    <!-- performsGenre -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#performsGenre">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Artist"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:label xml:lang="en">performs genre</rdfs:label>
        <rdfs:label xml:lang="fa">اجرا می‌کند گونه</rdfs:label>
    </owl:ObjectProperty>

    <!-- bornIn -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#bornIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Artist"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#Region"/>
        <rdfs:label xml:lang="en">born in</rdfs:label>
        <rdfs:label xml:lang="fa">متولد است در</rdfs:label>
    </owl:ObjectProperty>

    <!-- influencedBy -->
    <owl:ObjectProperty rdf:about="http://www.radionavahi.org/ontology/test#influencedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:range rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:label xml:lang="en">influenced by</rdfs:label>
        <rdfs:label xml:lang="fa">تأثیر گرفته از</rdfs:label>
    </owl:ObjectProperty>

    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatype Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- hasFloruitDate -->
    <owl:DatatypeProperty rdf:about="http://www.radionavahi.org/ontology/test#hasFloruitDate">
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#Artist"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:label xml:lang="en">has floruit date</rdfs:label>
        <rdfs:label xml:lang="fa">تاریخ زندگی</rdfs:label>
    </owl:DatatypeProperty>

    <!-- hasUNESCOInscription -->
    <owl:DatatypeProperty rdf:about="http://www.radionavahi.org/ontology/test#hasUNESCOInscription">
        <rdfs:domain rdf:resource="http://www.radionavahi.org/ontology/test#MusicalGenre"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has UNESCO ICH inscription</rdfs:label>
        <rdfs:label xml:lang="fa">شمارهٔ ثبت یونسکو</rdfs:label>
    </owl:DatatypeProperty>

    <!-- hasLatinTransliteration -->
    <owl:DatatypeProperty rdf:about="http://www.radionavahi.org/ontology/test#hasLatinTransliteration">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">Latin transliteration</rdfs:label>
        <rdfs:label xml:lang="fa">حرف‌نویسی لاتین</rdfs:label>
    </owl:DatatypeProperty>

