    <!-- MusicalGenre -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#MusicalGenre">
        <rdfs:label xml:lang="en">Musical Genre</rdfs:label>
        <rdfs:label xml:lang="fa">گونهٔ موسیقایی</rdfs:label>
    </owl:Class>

    <!-- RegionalRepertoire -->
    <owl:Class rdf:about="http://www.radionavahi.org/ontology/test#RegionalRepertoire">
